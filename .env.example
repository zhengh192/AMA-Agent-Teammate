# Copy to .env for local development. Never commit .env or real values.

# Application
AMA_ENV=development
AMA_LOG_LEVEL=INFO
AMA_API_HOST=127.0.0.1
AMA_API_PORT=8000
AMA_WEB_ORIGIN=http://localhost:5173
AMA_PROVIDER=mock
AMA_EMBEDDING_PROVIDER=mock
AMA_DEVELOPMENT_USER_ID=local-dev-user
AMA_DEVELOPMENT_USER_NAME=Local Developer
AMA_METADATA_DATABASE_URL=sqlite+aiosqlite:///./var/ama.db
AMA_ARTIFACT_ROOT=./var/artifacts
AMA_DEMO_DATABASE_ROOT=./var/demo-databases
AMA_SKILL_REGISTRY_ROOT=./skills/registry
AMA_SEMANTIC_METADATA_ROOT=./knowledge
AMA_CONVERSATION_HISTORY_MAX_MESSAGES=12
AMA_CONVERSATION_HISTORY_MAX_CHARACTERS=8000
AMA_MODEL_ASSISTED_ROUTING=true
AMA_ANALYSIS_SYNTHESIS=true

# Optional read-only Jira integration. The PAT is never stored in this file.
# On Windows, save it with current-user DPAPI at AMA_JIRA_PAT_DPAPI_PATH.
AMA_JIRA_ENABLED=false
AMA_JIRA_WRITE_ENABLED=false
AMA_JIRA_SEARCH_MAX_RESULTS=50
AMA_JIRA_BASE_URL=https://jira.example.com
AMA_JIRA_ALLOWED_PROJECTS=EXAMPLE
# Optional override: AMA_JIRA_PAT_DPAPI_PATH=C:\approved\user-scoped\jira_pat.dpapi
AMA_JIRA_TIMEOUT_SECONDS=10
AMA_JIRA_MAX_RESPONSE_BYTES=1048576
AMA_JIRA_COMMENT_LIMIT=20

# Azure OpenAI provider
# AZURE_OPENAI_DEPLOYMENT_* values are Azure deployment names, not public model IDs.
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_VERSION=replace-with-approved-api-version
AZURE_OPENAI_AUTH_MODE=entra_id
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT_COORDINATOR=replace-with-deployment-name
AZURE_OPENAI_DEPLOYMENT_ANALYST=replace-with-deployment-name
AZURE_OPENAI_DEPLOYMENT_CURATOR=replace-with-deployment-name
AZURE_OPENAI_DEPLOYMENT_RELIABILITY=replace-with-deployment-name
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=replace-with-embedding-deployment-name
AZURE_OPENAI_TIMEOUT_SECONDS=60
AZURE_OPENAI_MAX_RETRIES=2
AZURE_OPENAI_REASONING_EFFORT=medium
AZURE_OPENAI_MAX_OUTPUT_TOKENS=1024
AZURE_OPENAI_TOKEN_SCOPE=https://cognitiveservices.azure.com/.default

# LangGraph checkpointing (local MVP only)
AMA_CHECKPOINT_DATABASE_PATH=./var/checkpoints.db
AMA_CHECKPOINT_RETENTION_DAYS=30

# Execution defaults
AMA_REQUIRE_SQL_APPROVAL=true
AMA_TRUSTED_READONLY_MODE=false
AMA_QUERY_TIMEOUT_SECONDS=30
AMA_QUERY_MAX_ROWS=10000
AMA_QUERY_MAX_RESULT_BYTES=10485760
AMA_UPLOAD_MAX_BYTES=52428800
AMA_JOB_TIMEOUT_SECONDS=900
AMA_JOB_MAX_RETRIES=2

# Optional development tracing. Do not include raw sensitive payloads.
OTEL_SERVICE_NAME=ama-data-analysis-teammate
OTEL_EXPORTER_OTLP_ENDPOINT=

# Optional Super Agent UAT development connector.
# Keep real values in an ignored local env file or approved secret manager.
# Query mode is development-only and remains off by default; never commit real values.
AMA_SUPER_AGENT_UAT_HOST=
AMA_SUPER_AGENT_UAT_PORT=3306
AMA_SUPER_AGENT_UAT_DATABASE=sa_logs
AMA_SUPER_AGENT_UAT_USERNAME=
AMA_SUPER_AGENT_UAT_PASSWORD=
AMA_SUPER_AGENT_UAT_SSL_CA_PATH=
AMA_SUPER_AGENT_UAT_ALLOWED_TABLES=visit_log,turn_log,telemetry_log
AMA_SUPER_AGENT_UAT_CONNECT_TIMEOUT_SECONDS=10
AMA_SUPER_AGENT_UAT_READ_TIMEOUT_SECONDS=15
AMA_SUPER_AGENT_UAT_WRITE_TIMEOUT_SECONDS=10
AMA_SUPER_AGENT_UAT_QUERY_ENABLED=false
AMA_SUPER_AGENT_UAT_ALLOW_INSECURE_TRANSPORT=false
AMA_SUPER_AGENT_UAT_ALLOW_DETAIL_FIELDS=false
AMA_SUPER_AGENT_UAT_MAX_ROWS=500
AMA_SUPER_AGENT_UAT_MAX_RESULT_BYTES=262144
